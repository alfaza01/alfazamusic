    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "play-dl": "^1.9.7",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-player": "^3.4.0",
