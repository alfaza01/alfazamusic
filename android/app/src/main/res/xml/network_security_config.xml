<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Izinkan semua koneksi HTTPS ke internet (default Android) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Izinkan HTTP cleartext KHUSUS untuk localhost (development) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>

    <!-- Izinkan audio stream dari googlevideo.com (YouTube CDN) -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">googlevideo.com</domain>
        <domain includeSubdomains="true">youtube.com</domain>
        <domain includeSubdomains="true">ytimg.com</domain>
        <domain includeSubdomains="true">invidious.jing.rocks</domain>
        <domain includeSubdomains="true">iv.melmac.space</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
